!!!
%html
  %head
    %meta{ :charset => 'utf-8' }
    %meta{ :content => 'IE=edge,chrome=1', 'http-equiv': 'X-UA-Compatible' }
    %title= current_page.data.title || "Shanfan's Works"
    = stylesheet_link_tag 'all'
    = javascript_include_tag 'all'

  %body{ class: "#{page_classes}"}
    %nav
      %ul
        %li.logo
          %a{ :href => 'http://shanfanhuang.com'}
            = image_tag 'logo.png'
        %li.active
          Works
        %li 
          %a{ :href => 'http://shanfanhuang.com/everything'}
            Blog
        %li 
          %a{ :href => 'http://shanfanhuang.com/about' }
            About

    =yield